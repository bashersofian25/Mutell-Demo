# ── Application ──────────────────────────────────────────────
APP_NAME=Mutell
APP_ENV=development
DEBUG=true

# ── Security ────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-secure-random-string
ENCRYPTION_KEY=change-me-to-32-bytes-long-key

# ── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/mutell
DATABASE_URL_SYNC=postgresql://postgres:postgres@db:5432/mutell

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT ─────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# ── CORS ────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── S3 Storage (MinIO) ─────────────────────────────────────
S3_ENDPOINT_URL=http://s3:9000
S3_BUCKET=mutell-reports
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# ── Email (Mailpit) ────────────────────────────────────────
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@mutell.com

# ── AI Providers ────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
ZAI_API_KEY=
ZAI_BASE_URL=
DEEPSEEK_API_KEY=

# ── OAuth (Google) ──────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
